generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  preferences Json     @default("{}")
  updatedAt   DateTime @updatedAt
}

model Source {
  id       String   @id @default(cuid())
  name     String
  url      String
  type     String
  keywords String[]
}
